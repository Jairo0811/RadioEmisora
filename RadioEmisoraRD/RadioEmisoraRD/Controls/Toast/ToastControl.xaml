<UserControl x:Class="RadioEmisoraRD.Controls.Toast.ToastControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="340"
             Height="105">

    <Border Background="#121A30"
            CornerRadius="22"
            Padding="20"
            BorderBrush="#6A35FF"
            BorderThickness="1.3">

        <Border.Effect>
            <DropShadowEffect Color="#6A35FF"
                              BlurRadius="30"
                              ShadowDepth="0"
                              Opacity="0.35"/>
        </Border.Effect>

        <StackPanel>
            <TextBlock Text="{Binding ToastTitulo}"
                       Foreground="#FFD86B"
                       FontSize="15"
                       FontWeight="Bold"/>

            <TextBlock Text="{Binding ToastMensaje}"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</UserControl>
