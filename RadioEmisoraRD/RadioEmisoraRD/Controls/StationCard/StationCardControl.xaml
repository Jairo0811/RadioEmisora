<UserControl x:Class="RadioEmisoraRD.Controls.StationCard.StationCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="108">

    <Border Background="#121A30"
            CornerRadius="18"
            Padding="12"
            Margin="0,0,0,12"
            BorderBrush="#263253"
            BorderThickness="1">

        <Grid Width="245">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="62"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
            </Grid.ColumnDefinitions>

            <Border Width="54"
                    Height="54"
                    CornerRadius="14"
                    Background="#0A1023"
                    VerticalAlignment="Center">
                <Image Source="{Binding Logo}"
                       Width="48"
                       Height="48"
                       Stretch="Uniform"/>
            </Border>

            <StackPanel Grid.Column="1"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center">

                <TextBlock Text="{Binding Estado}"
                           Foreground="#FF5F5F"
                           FontSize="9"
                           FontWeight="Bold"
                           Margin="0,0,0,3"/>

                <TextBlock Text="{Binding Nombre}"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Text="{Binding Categoria}"
                           Foreground="#C0C8E0"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Text="{Binding Frecuencia}"
                           Foreground="#8D98B8"
                           FontSize="11"/>
            </StackPanel>

            <TextBlock Grid.Column="2"
                       Text="★"
                       Foreground="#FFD86B"
                       FontSize="16"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EsFavorita}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Border>
</UserControl>