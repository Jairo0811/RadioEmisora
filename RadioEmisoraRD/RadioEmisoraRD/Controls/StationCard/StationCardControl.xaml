<UserControl x:Class="RadioEmisoraRD.Controls.StationCard.StationCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="108">

    <Border x:Name="Card"
            CornerRadius="20"
            Padding="12"
            Margin="0,0,0,12"
            BorderThickness="1"
            RenderTransformOrigin="0.5,0.5">

        <Border.ToolTip>
            <ToolTip>
                <StackPanel>
                    <TextBlock Text="{Binding Nombre}" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Grupo}"/>
                    <TextBlock Text="{Binding Frecuencia}"/>
                    <TextBlock Text="{Binding Categoria}"/>
                    <TextBlock Text="{Binding Provincia}"/>
                </StackPanel>
            </ToolTip>
        </Border.ToolTip>

        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                    </Setter.Value>
                </Setter>

                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource CardHoverBrush}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                    </Trigger>

                    <DataTrigger Binding="{Binding EstaReproduciendo}" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        <Setter Property="BorderThickness" Value="2"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#6A35FF" BlurRadius="22" ShadowDepth="0" Opacity="0.45"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>

                    <DataTrigger Binding="{Binding EstaPausada}" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                        <Setter Property="BorderThickness" Value="2"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#FFD86B" BlurRadius="18" ShadowDepth="0" Opacity="0.35"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid Width="245">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="68"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="28"/>
            </Grid.ColumnDefinitions>

            <Border Width="58"
                    Height="58"
                    CornerRadius="16"
                    Background="#0A1023"
                    VerticalAlignment="Center">
                <Image Source="{Binding Logo}"
                       Width="50"
                       Height="50"
                       Stretch="Uniform"/>
            </Border>

            <StackPanel Grid.Column="1"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center">

                <TextBlock Text="{Binding EstadoCard}"
                           Foreground="#FF5F5F"
                           FontSize="9"
                           FontWeight="Bold"
                           Margin="0,0,0,3"/>

                <TextBlock Text="{Binding Nombre}"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Text="{Binding Categoria}"
                           Foreground="#C0C8E0"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Text="{Binding Frecuencia}"
                           Foreground="#8D98B8"
                           FontSize="11"/>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <TextBlock Text="▶"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="15"
                           FontWeight="Bold"
                           HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EstaReproduciendo}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Text="★"
                           Foreground="{StaticResource GoldBrush}"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EsFavorita}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>