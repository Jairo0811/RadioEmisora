<UserControl x:Class="RadioEmisoraRD.Controls.Player.PlayerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="110"/>
            <RowDefinition Height="95"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="28"
                Background="#0C1223"
                Padding="25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="270"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <Button Content="▶ Reproducir"
                            Width="230"
                            Height="65"
                            Background="{Binding ColorTemaBrush}"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ReproducirCommand}"/>

                    <Button Content="⏹ Detener"
                            Width="230"
                            Height="65"
                            Background="#E63355"
                            Style="{StaticResource PrimaryButton}"
                            Margin="30,0,0,0"
                            Command="{Binding DetenerCommand}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding VolumenTexto, StringFormat=🔊 Volumen: {0}}"
                               Foreground="#AAB4CD"
                               FontSize="14"
                               FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <Slider Minimum="0"
                            Maximum="1"
                            Value="{Binding Volumen}"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                CornerRadius="24"
                Background="#0C1223"
                Margin="0,25,0,0"
                Padding="25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="190"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding AhoraSuena}"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Text="▂▄▆█▇▅▄▂"
                           Foreground="{Binding ColorTemaBrush}"
                           FontSize="30"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
