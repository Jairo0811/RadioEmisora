<UserControl x:Class="RadioEmisoraRD.Controls.Dashboard.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#080C19">

        <Grid>
            <Ellipse Width="520"
                     Height="520"
                     Fill="#6A35FF"
                     Opacity="0.12"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Margin="0,-180,-120,0"/>

            <Ellipse Width="420"
                     Height="420"
                     Fill="#2DB4FF"
                     Opacity="0.07"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Bottom"
                     Margin="-160,0,0,-140"/>
        </Grid>

        <Border CornerRadius="34"
                Margin="55"
                Padding="48"
                BorderBrush="#6A35FF"
                BorderThickness="1.5">

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0A1023" Offset="0"/>
                    <GradientStop Color="#201446" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="150"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="📻 RadioEmisora RD"
                               Foreground="White"
                               FontSize="46"
                               FontWeight="Bold"
                               TextAlignment="Center"/>

                    <TextBlock Text="Bienvenido al rediseño moderno del proyecto original"
                               Foreground="#AAB4CD"
                               FontSize="18"
                               TextAlignment="Center"
                               Margin="0,8,0,32"/>
                </StackPanel>

                <UniformGrid Grid.Row="1"
                             Columns="4"
                             Margin="0,0,0,28">

                    <Border Background="#121A30" CornerRadius="22" Margin="8" Padding="22">
                        <StackPanel>
                            <TextBlock Text="📻 Emisoras" Foreground="#AAB4CD" FontSize="15"/>
                            <TextBlock Text="{Binding TotalEmisoras}" Foreground="White" FontSize="36" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#121A30" CornerRadius="22" Margin="8" Padding="22">
                        <StackPanel>
                            <TextBlock Text="⭐ Favoritas" Foreground="#AAB4CD" FontSize="15"/>
                            <TextBlock Text="{Binding TotalFavoritas}" Foreground="#FFD86B" FontSize="36" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#121A30" CornerRadius="22" Margin="8" Padding="22">
                        <StackPanel>
                            <TextBlock Text="📡 FM / AM" Foreground="#AAB4CD" FontSize="15"/>
                            <TextBlock Text="{Binding FmAmTexto}"
                                       Foreground="White"
                                       FontSize="30"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#121A30" CornerRadius="22" Margin="8" Padding="22">
                        <StackPanel>
                            <TextBlock Text="🌐 Online" Foreground="#AAB4CD" FontSize="15"/>
                            <TextBlock Text="{Binding TotalOnline}" Foreground="#2DB4FF" FontSize="36" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="2" Margin="8,0,8,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Historial reciente"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <Border Grid.Column="1"
                            Background="#121A30"
                            CornerRadius="18"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="🕒 Última emisora"
                                       Foreground="#AAB4CD"
                                       FontSize="14"/>
                            <TextBlock Text="{Binding UltimaEmisoraTexto}"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="3"
                        Background="#0C1223"
                        CornerRadius="24"
                        Padding="25"
                        Margin="8,0,8,28">

                    <ItemsControl ItemsSource="{Binding HistorialDashboard}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#121A30"
                                        CornerRadius="14"
                                        Padding="14"
                                        Margin="0,0,0,10">
                                    <TextBlock Text="{Binding}"
                                               Foreground="#DDE5FF"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <Button Grid.Row="4"
                        Content="▶ Entrar al reproductor"
                        Width="320"
                        Height="70"
                        Background="#6A35FF"
                        Foreground="White"
                        FontSize="19"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding EntrarReproductorCommand}"
                        HorizontalAlignment="Center"
                        Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>