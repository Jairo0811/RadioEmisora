<UserControl x:Class="RadioEmisoraRD.Controls.Sidebar.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:station="clr-namespace:RadioEmisoraRD.Controls.StationCard">

    <Border Background="{StaticResource SidebarBackgroundBrush}" Padding="22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="180"/>
                <RowDefinition Height="55"/>
                <RowDefinition Height="92"/>
                <RowDefinition Height="45"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Center">
                <TextBlock Text="🎧"
                           FontSize="54"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <TextBlock Text="RadioEmisora RD"
                           Foreground="White"
                           FontSize="29"
                           FontWeight="Bold"
                           TextAlignment="Center"/>

                <TextBlock Text="Tu música, tu compañía"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="15"
                           TextAlignment="Center"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Height="42"
                    CornerRadius="12"
                    Background="#18223C"
                    BorderBrush="#3A466A"
                    BorderThickness="1"
                    VerticalAlignment="Center">
                <Grid>
                    <TextBlock Text="Buscar emisora..."
                               Foreground="#7F8AAD"
                               FontSize="14"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TextoBusqueda}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TextoBusqueda}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBox Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#DDE5FF"
                             FontSize="15"
                             Padding="12,8"/>
                </Grid>
            </Border>

            <WrapPanel Grid.Row="2"
                       Margin="0,14,0,8">
                <Button Content="Todas"
                        Command="{Binding FiltroCommand}"
                        CommandParameter="Todas"
                        Style="{StaticResource FilterButton}"/>

                <Button Content="Favoritas"
                        Command="{Binding FiltroCommand}"
                        CommandParameter="Favoritas"
                        Style="{StaticResource FilterButton}"/>

                <Button Content="FM"
                        Command="{Binding FiltroCommand}"
                        CommandParameter="FM"
                        Style="{StaticResource FilterButton}"/>

                <Button Content="AM"
                        Command="{Binding FiltroCommand}"
                        CommandParameter="AM"
                        Style="{StaticResource FilterButton}"/>

                <Button Content="Online"
                        Command="{Binding FiltroCommand}"
                        CommandParameter="Online"
                        Style="{StaticResource FilterButton}"/>
            </WrapPanel>

            <TextBlock Grid.Row="3"
                       Text="{Binding TotalFiltradas, StringFormat=📻 EMISORAS DISPONIBLES: {0}}"
                       Foreground="{StaticResource InfoBrush}"
                       FontSize="15"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <ListBox Grid.Row="4"
                     ItemsSource="{Binding EmisorasFiltradas}"
                     SelectedItem="{Binding EmisoraSeleccionada}"
                     Style="{StaticResource StationListBox}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <station:StationCardControl/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</UserControl>
