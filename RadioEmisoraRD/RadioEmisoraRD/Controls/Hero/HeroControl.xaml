<UserControl x:Class="RadioEmisoraRD.Controls.Hero.HeroControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border CornerRadius="34"
            BorderBrush="{Binding ColorTemaBrush}"
            BorderThickness="1.6"
            Padding="0">

        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0A1023" Offset="0"/>
                <GradientStop Color="#121A30" Offset="0.55"/>
                <GradientStop Color="#201446" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Rectangle Height="8"
                       Fill="{Binding ColorTemaBrush}"
                       VerticalAlignment="Top"
                       RadiusX="34"
                       RadiusY="34"/>

            <Ellipse Width="360"
                     Height="360"
                     Fill="{Binding ColorTemaBrush}"
                     Opacity="0.12"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center"
                     Margin="0,0,-90,0"/>

            <Grid Margin="38">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="310"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding EstadoActual}"
                               Foreground="{Binding ColorTemaBrush}"
                               FontSize="16"
                               FontWeight="Bold"/>

                    <TextBlock Text="{Binding NombreActual}"
                               Foreground="White"
                               FontSize="50"
                               FontWeight="Bold"
                               Margin="0,16,0,8"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="{Binding CategoriaActual}"
                               Foreground="{Binding ColorTemaBrush}"
                               FontSize="23"
                               FontWeight="SemiBold"/>

                    <StackPanel Margin="0,22,0,0">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ProvinciaActual, StringFormat=📍 {0}}"
                                       Foreground="#AAB4CD"
                                       FontSize="16"/>

                            <TextBlock Text="   "/>

                            <TextBlock Text="{Binding TextoFavorito}"
                                       Foreground="#FFD86B"
                                       FontSize="16"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <TextBlock Text="{Binding GrupoActual, StringFormat=🏢 {0}}"
                                   Foreground="#AAB4CD"
                                   FontSize="16"
                                   Margin="0,8,0,0"/>

                        <TextBlock Text="{Binding StreamEstadoActual}"
                                   Foreground="#7F8AAD"
                                   FontSize="14"
                                   Margin="0,6,0,0"/>

                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Width="250"
                        Height="250"
                        CornerRadius="42"
                        Background="#121A30"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                    <Border.Effect>
                        <DropShadowEffect Color="#7B4CFF"
                                          BlurRadius="42"
                                          ShadowDepth="0"
                                          Opacity="0.55"/>
                    </Border.Effect>

                    <Image Source="{Binding LogoActual}"
                           Width="210"
                           Height="210"
                           Stretch="Uniform"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>