<UserControl x:Class="RadioEmisoraRD.Controls.Hero.HeroControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border CornerRadius="30"
            BorderBrush="{Binding ColorTemaBrush}"
            BorderThickness="1.5"
            Padding="35">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0A1023" Offset="0"/>
                <GradientStop Color="#141033" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding EstadoActual}"
                           Foreground="{Binding ColorTemaBrush}"
                           FontSize="16"
                           FontWeight="Bold"/>

                <TextBlock Text="{Binding NombreActual}"
                           Foreground="White"
                           FontSize="48"
                           FontWeight="Bold"
                           Margin="0,18,0,6"
                           TextWrapping="Wrap"/>

                <TextBlock Text="{Binding CategoriaActual}"
                           Foreground="{Binding ColorTemaBrush}"
                           FontSize="23"/>

                <StackPanel Orientation="Horizontal"
                            Margin="0,20,0,0">
                    <TextBlock Text="{Binding ProvinciaActual, StringFormat=📍 {0}}"
                               Foreground="#AAB4CD"
                               FontSize="16"/>

                    <TextBlock Text="   "/>

                    <TextBlock Text="{Binding TextoFavorito}"
                               Foreground="#FFD86B"
                               FontSize="16"
                               FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Column="1"
                    Width="240"
                    Height="240"
                    CornerRadius="38"
                    Background="#121A30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#7B4CFF"
                                      BlurRadius="38"
                                      ShadowDepth="0"
                                      Opacity="0.48"/>
                </Border.Effect>

                <Image Source="{Binding LogoActual}"
                       Width="198"
                       Height="198"
                       Stretch="Uniform"/>
            </Border>
        </Grid>
    </Border>
</UserControl>