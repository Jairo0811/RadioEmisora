<Window x:Class="RadioEmisoraRD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sidebar="clr-namespace:RadioEmisoraRD.Controls.Sidebar"
        xmlns:hero="clr-namespace:RadioEmisoraRD.Controls.Hero"
        xmlns:player="clr-namespace:RadioEmisoraRD.Controls.Player"
        xmlns:dashboard="clr-namespace:RadioEmisoraRD.Controls.Dashboard"
        xmlns:toast="clr-namespace:RadioEmisoraRD.Controls.Toast"
        Title="RadioEmisora RD"
        Width="1200"
        Height="720"
        MinWidth="1100"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#080C19">

    <Grid>

        <Grid Visibility="{Binding MainLayoutVisibility}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <sidebar:SidebarControl Grid.Column="0"/>

            <Grid Grid.Column="1" Margin="35">
                <Grid.RowDefinitions>
                    <RowDefinition Height="290"/>
                    <RowDefinition Height="245"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <hero:HeroControl Grid.Row="0"/>

                <player:PlayerControl Grid.Row="1"
                                      Margin="0,25,0,0"/>

                <Border Grid.Row="2"
                        CornerRadius="24"
                        Background="#0A1023"
                        Margin="0,25,0,0"
                        Padding="22">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="RadioEmisoraRD • WPF • MVVM • Inspirado en el proyecto original"
                                   Foreground="#7F8AAD"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Content="↻ Actualizar"
                                Height="48"
                                Background="#0072E5"
                                Style="{StaticResource PrimaryButton}"
                                FontSize="14"
                                Command="{Binding ActualizarCommand}"/>

                        <Button Grid.Column="2"
                                Content="{Binding TextoFavorito}"
                                Height="48"
                                Background="#6A35FF"
                                Style="{StaticResource PrimaryButton}"
                                FontSize="14"
                                Margin="12,0,0,0"
                                Command="{Binding FavoritoCommand}"/>

                        <Button Grid.Column="3"
                                Content="ⓘ Acerca de"
                                Height="48"
                                Background="#008899"
                                Style="{StaticResource PrimaryButton}"
                                FontSize="14"
                                Margin="12,0,0,0"
                                Command="{Binding AcercaDeCommand}"/>

                        <Button Grid.Column="4"
                                Content="Salir"
                                Height="48"
                                Background="#C41535"
                                Style="{StaticResource PrimaryButton}"
                                FontSize="14"
                                Margin="12,0,0,0"
                                Command="{Binding SalirCommand}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <dashboard:DashboardControl Visibility="{Binding DashboardVisibility}"/>

        <toast:ToastControl Visibility="{Binding ToastVisibility}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,35,35"/>

    </Grid>
</Window>